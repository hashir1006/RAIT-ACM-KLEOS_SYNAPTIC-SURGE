# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Public (frontend) configuration - These keys are safe for public use
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Secret (backend only) - NEVER expose this key to frontend
# Get from: Supabase Dashboard → Settings → API (Service Role Key)
# ⚠️  CRITICAL: This key should ONLY be in .env (not .env.example or version control)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# ENCRYPTION CONFIGURATION
# ============================================================================

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: Use strong, random, 32-byte base64 string
# Store securely - used for AES-256-GCM encryption
ENCRYPTION_SECRET=your_encryption_secret_here_base64_32bytes

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used to sign and verify JWT tokens
# Keep secret and secure
JWT_SECRET=your_jwt_secret_here_32bytes

# ============================================================================
# GOOGLE GEMINI API
# ============================================================================

# Get from: Google Cloud Console → AI Studio → Create API key
# Used for: Invoice OCR processing, GST Assistant chatbot
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Frontend URL (used for CORS and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Environment
NODE_ENV=development

# ============================================================================
# OPTIONAL: AWS S3 (Alternative to Supabase Storage)
# ============================================================================

# Uncomment if using S3 instead of Supabase Storage
# AWS_S3_BUCKET=your_bucket_name
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================================================
# OPTIONAL: DATABASE DIRECT ACCESS (For migrations)
# ============================================================================

# Uncomment if you need direct PostgreSQL access (rare)
# DATABASE_URL=postgresql://user:password@host:5432/database_name

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable detailed logs for debugging
DEBUG=false
